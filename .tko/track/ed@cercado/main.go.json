            "label": "2026-05-19_18-10-27",
            "content": "package main\n\nimport (\n\t\"bufio\"\n\t\"fmt\"\n\t\"os\"\n)\n\n// N\u00c3O ALTERE A ASSINATURA DA FUN\u00c7\u00c3O solve\nfunc solve(board [][]byte) {\n\tif len(board) == 0 {\n\t\treturn\n\t}\n\tvisited := make(map[int]bool)\n\trows := len(board)\n\tcols := len(board[0])\n\tfor i := 0; i < len(board); i++ {\n\t\tfor j := 0; j < cols; j++ {\n\t\t\tif (i == 0 || i == rows-1 || j == 0 || j == cols-1) && board[i][j] == 'O' {\n\t\t\t\tdfs(board, i, j, visited, cols)\n\t\t\t}\n\t\t}\n\t}\n\n\tfor i := 0; i < rows; i++ {\n\t\tfor j := 0; j < cols; j++ {\n\t\t\tif !visited[i*cols+j] && board[i][j] == 'O' {\n\t\t\t\tboard[i][j] = 'X'\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc dfs(board [][]byte, i, j int, visited map[int]bool, cols int) {\n\tif i < 0 || i >= len(board) || j < 0 || j >= cols || board[i][j] != 'O' || visited[i*cols+j] {\n\t\treturn\n\t}\n\n\tvisited[i*cols+j] = true\n\n\tdfs(board, i+1, j, visited, cols)\n\tdfs(board, i-1, j, visited, cols)\n\tdfs(board, i, j+1, visited, cols)\n\tdfs(board, i, j-1, visited, cols)\n}\n\n// N\u00c3O ALTERE A MAIN\nfunc main() {\n\tscanner := bufio.NewScanner(os.Stdin)\n\tscanner.Scan()\n\tvar nrows, ncols int\n\tfmt.Sscanf(scanner.Text(), \"%d %d\", &nrows, &ncols)\n\tboard := make([][]byte, nrows)\n\tfor i := 0; i < nrows; i++ {\n\t\tscanner.Scan()\n\t\tboard[i] = []byte(scanner.Text())\n\t}\n\tsolve(board)\n\tfor _, row := range board {\n\t\tfmt.Println(string(row))\n\t}\n}\n",
