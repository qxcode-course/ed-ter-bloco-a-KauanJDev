        {
            "label": "2026-04-13_17-26-53",
            "content": "package main\n\nimport (\n\t\"fmt\"\n\t\"math/rand\"\n)\n\nfunc ri(inf, sup int) float64 {\n\treturn float64(rand.Intn(sup-inf+1) + inf)\n}\n\nfunc arvore(pen *Pen, distancia float64) {\n\tif distancia < 10 {\n\t\treturn\n\t}\n\n\tang_dir := ri(10, 40)\n\tang_esq := ri(10, 40)\n\n\tpen.SetRGB(0, 0, 0)\n\tpen.Walk(distancia)\n\tpen.Right(ang_dir)\n\tarvore(pen, distancia*(ri(80, 85)/100))\n\tpen.Left(ang_dir + ang_esq)\n\tarvore(pen, distancia*(ri(80, 85)/100))\n\tpen.Right(ang_esq)\n\tpen.Walk(-distancia)\n\n}\n\nfunc main() {\n\tpen := NewPen(500, 800)\n\tpen.Up()\n\tpen.SetHeading(90)\n\tpen.SetPosition(250, 800)\n\tpen.Down()\n\tarvore(pen, 200)\n\tpen.SavePNG(\"arvore.png\")\n\tfmt.Printf(\"salvou\")\n}\n",
